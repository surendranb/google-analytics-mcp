{
  "mcpServers": {
    "ga4-analytics": {
      "command": "/path/to/your/google-analytics-mcp/.venv/bin/python",
      "args": ["-m", "ga4_mcp"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "/path/to/your/service-account-key.json",
        "GA4_PROPERTY_ID": "your-property-id-here"
      }
    }
  }
}
